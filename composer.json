{
    "name": "safemood/discountify",
    "description": "Laravel package for dynamic discounts with custom conditions.",
    "keywords": [
        "Safemood",
        "laravel",
        "discountify"
    ],
    "homepage": "https://github.com/safemood/discountify",
    "license": "MIT",
    "authors": [
        {
            "name": "Khalil Bouzidi",
            "email": "kbouziditn@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11|^12|^13",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/extension-installer": "^1.3",
        "laravel/pint": "^1.13",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Safemood\\Discountify\\": "src/",
            "Safemood\\Discountify\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Safemood\\Discountify\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-discountify --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage",
        "type-coverage": "vendor/bin/pest --type-coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Safemood\\Discountify\\DiscountifyServiceProvider"
            ],
            "aliases": {
                "Discountify": "Safemood\\Discountify\\Facades\\Discountify"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}