{
    "name": "safemood/discountify",
    "description": "Laravel package for dynamic discounts — full condition engine, coupon and promo support, database-driven.",
    "keywords": ["laravel", "discounts", "coupons", "promos", "conditions"],
    "license": "MIT",
    "type": "library",
    "version": "2.0.0",
    "authors": [{"name": "Khalil Bouzidi", "email": "bouzidi.khalil47@gmail.com"}],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {"Safemood\\Discountify\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Safemood\\Discountify\\Tests\\": "tests/"}
    },
    "extra": {
        "laravel": {
            "providers": ["Safemood\\Discountify\\DiscountifyServiceProvider"],
            "aliases": {
                "Discountify": "Safemood\\Discountify\\Facades\\Discountify",
                "Condition": "Safemood\\Discountify\\Facades\\Condition"
            }
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest --colors=always",
        "test:coverage": "./vendor/bin/pest --coverage",
        "lint": "./vendor/bin/pint",
        "analyse": "./vendor/bin/phpstan analyse --memory-limit=1G"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
